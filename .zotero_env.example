# Copy this file to ~/.zotero_env and fill in your own values.
#   cp .zotero_env.example ~/.zotero_env
#
# DO NOT commit your filled-in ~/.zotero_env anywhere. The skill reads these
# three variables at runtime; no credentials are stored in the repo.

# Your numeric Zotero library ID.
#   - Personal library: your userID from https://www.zotero.org/settings/security
#     (the "Applications" section shows it next to your API keys).
#   - Group library: the group's numeric ID from its URL.
ZOTERO_LIBRARY_ID=0000000

# "user" for a personal library, "group" for a group library.
ZOTERO_LIBRARY_TYPE=user

# A Zotero Web API key with read + write access to that library.
# Create one at https://www.zotero.org/settings/security -> "Create new private key".
ZOTERO_API_KEY=replace-with-your-zotero-api-key
